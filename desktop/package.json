{
  "name": "binance-ai-trading-bot-desktop",
  "version": "0.1.0",
  "description": "Desktop shell for the Codex AI Trading Bot dashboard and local bot runtime.",
  "author": "mrcryptolife420",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "set DESKTOP_DEBUG=1&& electron .",
    "dist": "electron-builder --win",
    "dist:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$out='dist-new-'+(Get-Date -Format yyyyMMdd-HHmmss); if (-not $env:BUILD_COMMIT) { $env:BUILD_COMMIT='local' }; npx electron-builder --win --config.directories.output=$out\"",
    "dist:dir": "electron-builder --win --dir",
    "clean": "node scripts/clean-desktop-dist.mjs",
    "diagnose": "node scripts/desktop-diagnose.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mrcryptolife420.newnewaitradingbot",
    "productName": "Codex AI Trading Bot",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "bot",
        "filter": [
          "src/**",
          "scripts/**",
          "config/**",
          ".env.example",
          "package.json",
          "package-lock.json",
          "node_modules/**",
          "!node_modules/.cache/**",
          "!data/**",
          "!tmp/**",
          "!logs/**",
          "!.env"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-${env.BUILD_COMMIT}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
