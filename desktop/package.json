{
  "name": "binance-ai-trading-bot-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mrcryptolife420.newnewaitradingbot",
    "productName": "Codex AI Trading Bot",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "..",
        "to": "bot",
        "filter": [
          "src/**",
          "scripts/**",
          "config/**",
          ".env.example",
          "package.json",
          "package-lock.json",
          "node_modules/**",
          "!node_modules/.cache/**",
          "!data/**",
          "!tmp/**",
          "!logs/**",
          "!.env"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
