# Safety first: the bot starts in paper mode unless you set BOT_MODE=live.
# For Binance Spot testnet, set BINANCE_API_BASE_URL=https://testnet.binance.vision
# For Binance Spot demo mode in this repo, set BINANCE_API_BASE_URL=https://demo-api.binance.com
# For USDⓈ-M futures demo market-data context, set BINANCE_FUTURES_API_BASE_URL=https://demo-fapi.binance.com
