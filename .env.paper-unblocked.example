# Paper unblocked profile
# Copy this file to .env when you want the bot to learn in PAPER mode without staying stuck behind soft blockers.
# This intentionally does NOT enable live trading and does NOT bypass hard exchange/reconcile safety.

BOT_MODE=paper
OPERATOR_MODE=active
USER_REGION=BE
BASE_QUOTE_ASSET=USDT
STARTING_CASH=10000
RUNTIME_DIR=./data/runtime
HISTORY_DIR=./data/history
HISTORY_CACHE_ENABLED=true

# Keep paper fully internal to avoid Binance demo exchange-truth / lifecycle freezes while debugging learning.
# Use binance_demo_spot only after reconcile/exchange-safety is clean.
PAPER_EXECUTION_VENUE=internal
PAPER_MODE_PROFILE=research
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE_URL=
BINANCE_FUTURES_API_BASE_URL=
BINANCE_RECV_WINDOW=5000
LIVE_TRADING_ACKNOWLEDGED=
ENABLE_EXCHANGE_PROTECTION=true
ALLOW_RECOVER_UNSYNCED_POSITIONS=false
ENABLE_AUTO_RECONCILE=true
AUTO_RECONCILE_ENABLED=true
AUTO_RECONCILE_DRY_RUN=false
AUTO_RECONCILE_ALLOW_FLAT_CLOSE=true
AUTO_RECONCILE_ALLOW_PROTECTIVE_REBUILD=true
AUTO_RECONCILE_REQUIRE_FRESH_STREAM_OR_REST=true
AUTO_RECONCILE_MIN_CONFIDENCE=0.78
AUTO_RECONCILE_MAX_ACTIONS_PER_RUN=5
EXCHANGE_TRUTH_FREEZE_MISMATCH_COUNT=3
EXCHANGE_TRUTH_RECENT_FILL_LOOKBACK_MINUTES=20

# Smaller, cleaner universe: prevents REST pressure and avoids random weak alts dominating the board.
ENABLE_DYNAMIC_WATCHLIST=false
WATCHLIST=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,LINKUSDT,AVAXUSDT,DOGEUSDT,TRXUSDT,LTCUSDT,BCHUSDT,SUIUSDT,UNIUSDT,AAVEUSDT
WATCHLIST_TOP_N=40
WATCHLIST_FETCH_PER_PAGE=100
DYNAMIC_WATCHLIST_MIN_SYMBOLS=15
WATCHLIST_EXCLUDE_STABLECOINS=true
WATCHLIST_EXCLUDE_LEVERAGED_TOKENS=true
WATCHLIST_INCLUDE=
WATCHLIST_EXCLUDE=
ENABLE_UNIVERSE_SELECTOR=true
UNIVERSE_MAX_SYMBOLS=12
UNIVERSE_MIN_SCORE=0.30
UNIVERSE_MIN_DEPTH_CONFIDENCE=0.12
UNIVERSE_MIN_DEPTH_USD=15000
UNIVERSE_TARGET_VOL_PCT=0.018
UNIVERSE_ROTATION_BOOST=0.05
UNIVERSE_ROTATION_MAX_COOLING_CLUSTERS=1
MARKET_SNAPSHOT_BUDGET_SYMBOLS=12
LOCAL_BOOK_MAX_SYMBOLS=12
MARKET_SNAPSHOT_CONCURRENCY=3
MARKET_SNAPSHOT_CACHE_MINUTES=2

# Reduce REST pressure: prefer streams/local book, slow down REST fallbacks.
ENABLE_EVENT_DRIVEN_DATA=true
ENABLE_LOCAL_ORDER_BOOK=true
PUBLIC_STREAM_MAX_STREAMS_PER_CONNECTION=120
PUBLIC_STREAM_STARTUP_WAIT_MS=4500
PUBLIC_STREAM_STALE_MS=180000
PUBLIC_STREAM_MONITOR_INTERVAL_MS=45000
USER_STREAM_STARTUP_WAIT_MS=2500
STREAM_TRADE_BUFFER_SIZE=160
STREAM_DEPTH_LEVELS=20
STREAM_DEPTH_SNAPSHOT_LIMIT=200
MAX_DEPTH_EVENT_AGE_MS=30000
LOCAL_BOOK_BOOTSTRAP_WAIT_MS=700
LOCAL_BOOK_WARMUP_MS=3500
REST_MARKET_DATA_FALLBACK_MIN_MS=90000
REST_BOOK_TICKER_FALLBACK_MIN_MS=120000
REST_DEPTH_FALLBACK_MIN_MS=300000
REST_TIMEFRAME_FALLBACK_MIN_MS=120000
REQUEST_WEIGHT_BACKOFF_MAX_MS=120000
REQUEST_WEIGHT_WARN_THRESHOLD_1M=4800
REST_HOT_CALLER_DEPTH_WEIGHT_THRESHOLD=3000
REST_HOT_CALLER_PRIVATE_TRADE_WEIGHT_THRESHOLD=1500
EXCHANGE_INFO_CACHE_MS=21600000

# Paper sizing: small enough to learn, not so small that min-notional blocks everything.
MAX_OPEN_POSITIONS=2
MAX_POSITION_FRACTION=0.08
MAX_TOTAL_EXPOSURE_FRACTION=0.20
POST_RECONCILE_MAX_OPEN_POSITIONS=1
POST_RECONCILE_PAPER_MAX_OPEN_POSITIONS=2
POST_RECONCILE_MAX_NEW_ENTRIES_PER_CYCLE=1
POST_RECONCILE_MAX_TOTAL_EXPOSURE_MULTIPLIER=0.35
POST_RECONCILE_PAPER_SIZE_MULTIPLIER=0.35
RISK_PER_TRADE=0.003
MAX_DAILY_DRAWDOWN=0.03
MIN_TRADE_USDT=10
PAPER_MIN_TRADE_USDT=5
MAX_ENTRIES_PER_DAY=20
MAX_ENTRIES_PER_SYMBOL_PER_DAY=3
ENTRY_COOLDOWN_MINUTES=8
SYMBOL_LOSS_COOLDOWN_MINUTES=45
MAX_LOSS_STREAK=4
MAX_SYMBOL_LOSS_STREAK=3
DAILY_RISK_BUDGET_FLOOR=0.45
CAPITAL_GOVERNOR_WEEKLY_DRAWDOWN_PCT=0.12
