THRESHOLD_PROBATION_MIN_TRADES=4
THRESHOLD_PROBATION_WINDOW_DAYS=5
THRESHOLD_PROBATION_MAX_AVG_PNL_DROP_PCT=0.02
THRESHOLD_PROBATION_MAX_WIN_RATE_DROP=0.12
THRESHOLD_RELAX_STEP=0.015
THRESHOLD_TIGHTEN_STEP=0.008
