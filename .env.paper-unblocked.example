PAPER_LEARNING_SHADOW_DAILY_LIMIT=50
PAPER_LEARNING_NEAR_MISS_THRESHOLD_BUFFER=0.10
PAPER_LEARNING_MAX_PROBE_PER_FAMILY_PER_DAY=8
PAPER_LEARNING_MAX_PROBE_PER_REGIME_PER_DAY=8
PAPER_LEARNING_MAX_PROBE_PER_SESSION_PER_DAY=8
PAPER_LEARNING_MAX_CONCURRENT_POSITIONS=4
