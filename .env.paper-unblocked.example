CAPITAL_GOVERNOR_MIN_SIZE_MULTIPLIER=0.22
PORTFOLIO_MAX_CVAR_PCT=0.05
PORTFOLIO_DRAWDOWN_BUDGET_PCT=0.06
PORTFOLIO_REGIME_KILL_SWITCH_LOSS_STREAK=4

# Paper learning: allow bounded learning probes when soft blockers dominate.
PAPER_EXPLORATION_ENABLED=true
PAPER_EXPLORATION_THRESHOLD_BUFFER=0.20
PAPER_EXPLORATION_SIZE_MULTIPLIER=0.35
PAPER_EXPLORATION_COOLDOWN_MINUTES=15
PAPER_EXPLORATION_MIN_BOOK_PRESSURE=-0.55
PAPER_RECOVERY_PROBE_ENABLED=true
PAPER_RECOVERY_PROBE_THRESHOLD_BUFFER=0.15
PAPER_RECOVERY_PROBE_SIZE_MULTIPLIER=0.25
PAPER_RECOVERY_PROBE_COOLDOWN_MINUTES=20
PAPER_RECOVERY_PROBE_MIN_BOOK_PRESSURE=-0.50
PAPER_SOFT_BLOCKER_PROBE_ENABLED=true
