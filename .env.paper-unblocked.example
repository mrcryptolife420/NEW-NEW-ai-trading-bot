PAPER_LEARNING_MIN_DATA_QUALITY=0.35
PAPER_LEARNING_MIN_NOVELTY_SCORE=0.05
PAPER_LEARNING_SANDBOX_ENABLED=true
PAPER_LEARNING_SANDBOX_MIN_CLOSED_TRADES=2
PAPER_LEARNING_SANDBOX_MAX_THRESHOLD_SHIFT=0.02
BASELINE_CORE_ENABLED=true

# Model/gates: lowest valid threshold allowed by current validator, with softer paper governance.
MODEL_THRESHOLD=0.50
MIN_MODEL_CONFIDENCE=0.50
MIN_CALIBRATION_CONFIDENCE=0.10
MIN_REGIME_CONFIDENCE=0.28
ABSTAIN_BAND=0.01
