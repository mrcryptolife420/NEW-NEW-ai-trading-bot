MODEL_PROMOTION_MAX_PAPER_DRAWDOWN_PCT=0.10
MODEL_PROMOTION_MIN_PAPER_QUALITY=0.50
MODEL_PROMOTION_MIN_LIVE_TRADES=5
MODEL_PROMOTION_MIN_LIVE_QUALITY=0.54
MODEL_PROMOTION_PROBATION_LIVE_TRADES=4

# Strategies: disable quarantined range-grid path for now; keep simpler trend/reversion routes active.
ENABLE_STRATEGY_ROUTER=true
ENABLE_RANGE_GRID_STRATEGY=false
ENABLE_LIVE_RANGE_GRID=false
ENABLE_BREAKOUT_RETEST_STRATEGY=false
BREAKOUT_RETEST_PAPER_ONLY=true
